  {
    "id": "mysql_function",
    "type": "function",
    "z": "tab1",
    "name": "Insert SQL",
    "func": "let t = msg.payload.temperatura;\nlet u = msg.payload.umidade;\nlet l = msg.payload.luminosidade;\nmsg.topic = `INSERT INTO leituras (temperatura, umidade, luminosidade) VALUES (${t}, ${u}, ${l})`;\nreturn msg;",
    "outputs": 1,
    "timeout": "",
    "noerr": 0,
    "x": 530,
    "y": 180,
    "wires": [["mysql_1"]]
  },
