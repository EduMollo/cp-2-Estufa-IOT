  {
    "id": "http_clima",
    "type": "http request",
    "z": "tab1",
    "name": "OpenWeather",
    "method": "GET",
    "ret": "obj",
    "paytoqs": "ignore",
    "url": "https://api.openweathermap.org/data/2.5/weather?q=Campinas&appid=SUA_API_KEY&units=metric&lang=pt_br",
    "tls": "",
    "persist": false,
    "proxy": "",
    "insecureHTTPParser": false,
    "authType": "",
    "senderr": false,
    "headers": [],
    "x": 330,
