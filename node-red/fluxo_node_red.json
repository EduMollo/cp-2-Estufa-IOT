    "wires": [["function_clima"]]
  },
  {
    "id": "function_clima",
    "type": "function",
    "z": "tab1",
    "name": "Tratar clima",
    "func": "msg.payload = {\n    temperatura_externa: msg.payload.main.temp,\n    umidade_externa: msg.payload.main.humidity,\n    descricao: msg.payload.weather[0].description\n};\nreturn [\n    { payload: msg.payload.temperatura_externa },\n    { payload: msg.payload.umidade_externa },\n    { payload: msg.payload.descricao }\n];",
    "outputs": 3,
    "timeout": "",
    "noerr": 0,
    "x": 530,
    "y": 460,
    "wires": [["gauge_temp_ext"], ["gauge_umid_ext"], ["text_clima"]]
  },
